{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build-test": "nuxt build --dotenv .env.test",
    "build-prod": "nuxt build --dotenv .env.prod",
    "start": "nuxt dev",
    "typecheck": "nuxt typecheck && eslint .",
    "lint": "eslint .",
    "generate": "nuxt generate",
