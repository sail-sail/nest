    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@una-ui/nuxt": "1.0.0-alpha.17",
    "decimal.js": "10.6.0",
    "file-saver": "2.0.5",
    "graphql": "16.13.2",
    "graphql-combine-query": "1.2.4",
    "vue": "3.5.32",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@iconify-json/lucide": "1.2.101",
    "@iconify-json/tabler": "1.2.33",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/icon": "2.2.1",
    "@types/file-saver": "2.0.7",
    "@types/node": "25.5.2",
    "@unocss/nuxt": "66.6.7",
    "@unocss/preset-rem-to-px": "66.6.7",
    "@unocss/transformer-directives": "66.6.7",
    "@vue-macros/nuxt": "3.1.2",
    "@vue-macros/reactivity-transform": "3.1.2",
    "nuxt": "4.4.2",
    "sass": "1.99.0",
    "typescript": "6.0.2",
    "unocss": "66.6.7",
    "vue-tsc": "3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "oxc-resolver",
