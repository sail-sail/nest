{
  "plugins": [
    "oxc",
    "typescript",
    "unicorn",
    "react",
    "vue"
  ],
  "ignorePatterns": [
    "src/typings/**",
    "src/assets/**",
    "src/typings/**",
    "*.d.ts"
  ],
  "rules": {
    "unicorn/no-single-promise-in-promise-methods": "allow",
    "unicorn/no-useless-spread": "allow",
    "@typescript-eslint/no-unused-vars": "allow"
  }
}