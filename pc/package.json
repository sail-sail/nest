{
  "name": "pc",
  "version": "0.0.0",
  "scripts": {
    "start": "vp dev",
    "preview": "set NODE_OPTIONS=--max-old-space-size=4096 && vp preview",
    "test": "vp test",
    "coverage": "vp test run --coverage",
    "build-prod": "set NODE_OPTIONS=--max-old-space-size=4096 && vp build --emptyOutDir && node src/utils/postbuild.js",
    "build-test": "set NODE_OPTIONS=--max-old-space-size=4096 && vp build --mode test --emptyOutDir && node src/utils/postbuild.js",
    "permit": "node src/utils/permit_scan.js",
    "rsw:build": "rsw && npm run build",
    "typecheck": "set NODE_OPTIONS=--max-old-space-size=4096 && vue-tsc --noEmit --skipLibCheck && vp lint .",
    "lint": "vp lint .",
    "lint-staged": "lint-staged",
    "codegen": "cd .. && npm run codegen",
    "sql": "cd ../codegen && node --experimental-strip-types src/util/npmSql.ts",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "node src/utils/postinstall.js"
  },
  "dependencies": {
    "@element-plus/icons-vue": "2.3.2",
    "@jsquash/resize": "2.1.1",
    "@jsquash/webp": "1.5.0",
    "@logicflow/core": "2.1.11",
    "@logicflow/extension": "2.1.15",
    "@opentiny/fluent-editor": "3.25.11",
    "@qr-x/vue": "1.1.1",
    "@vue-flow/background": "1.3.2",
    "@vue-flow/controls": "1.1.3",
    "@vue-flow/core": "1.48.2",
    "@vue-flow/minimap": "1.5.4",
    "@vue-office/docx": "1.6.3",
    "@vue-office/excel": "1.7.14",
    "@vue/reactivity": "3.5.31",
    "@vue/runtime-dom": "3.5.31",
    "@vue/shared": "3.5.31",
    "@vueuse/core": "14.2.1",
    "cronstrue": "3.14.0",
    "danmu": "0.20.0",
    "dayjs": "1.11.20",
    "decimal.js": "10.6.0",
    "docx-handlebars": "0.3.3",
    "ejsexcel-browserify": "4.4.3",
    "element-plus": "2.13.6",
    "expr-eval": "2.0.2",
    "file-saver": "2.0.5",
    "filesize": "11.0.15",
    "graphql": "16.13.2",
    "graphql-combine-query": "1.2.4",
    "jszip": "3.10.1",
    "numeral": "2.0.6",
    "pinyin-pro": "3.28.0",
    "sortablejs": "1.15.7",
    "swiper": "12.1.3",
    "vue": "3.5.31",
    "vue-countup-v3": "1.4.2",
    "vue-demi": "0.14.10",
    "vue-router": "5.0.4",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "xlsx-handlebars": "0.2.2"
  },
  "devDependencies": {
    "@plugin-web-update-notification/vite": "2.1.0",
    "@types/file-saver": "2.0.7",
    "@types/node": "25.5.0",
    "@types/sortablejs": "1.15.9",
    "@unocss/preset-rem-to-px": "66.6.7",
    "@vitejs/plugin-vue": "6.0.5",
    "@vitejs/plugin-vue-jsx": "5.1.5",
    "@vue-macros/reactivity-transform": "3.1.2",
    "@vue/compiler-sfc": "3.5.31",
    "@vue/devtools-api": "8.1.1",
    "@vue/runtime-core": "3.5.31",
    "dotenv": "17.3.1",
    "globals": "17.4.0",
    "mysql2": "3.20.0",
    "oxlint": "1.58.0",
    "sass": "1.98.0",
    "spark-md5": "3.0.2",
    "svgo": "4.0.1",
    "typescript": "6.0.2",
    "unocss": "66.6.7",
    "unplugin-auto-import": "21.0.0",
    "unplugin-icons": "23.0.1",
    "unplugin-turbo-console": "2.3.0",
    "unplugin-vue-components": "32.0.0",
    "unplugin-vue-define-options": "3.1.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-devtools-json": "1.0.0",
    "vite-plugin-inspect": "12.0.0-beta.1",
    "vite-plugin-pwa": "1.2.0",
    "vite-plugin-vue-devtools": "8.1.1",
    "vite-plugin-vue-inspector": "5.4.0",
    "vite-plugin-wasm": "3.6.0",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vue-tsc": "3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@vue-office/docx",
      "@vue-office/excel",
      "esbuild",
      "vue-demi"
    ],
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
